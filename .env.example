# ============================================================
#  MoM Generator Bot - Environment Variables Template
#  Copy this file to .env and fill in your actual values
# ============================================================

# OpenAI API Key (required for GPT summarization)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# GPT Model to use for summarization
# Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo
GPT_MODEL=gpt-4

# Whisper model size for transcription
# Options: tiny, base, small, medium, large, large-v2, large-v3
# Recommendation: medium (good accuracy + speed balance)
# For Hindi: large or large-v2 gives better results
WHISPER_MODEL=medium

# Maximum audio chunk duration in seconds for long meetings
# Default: 600 seconds (10 minutes per chunk)
CHUNK_DURATION_SECONDS=600

# Output directory for generated MoM files
OUTPUT_DIR=outputs

# Upload directory for temporary files
UPLOAD_DIR=uploads

# Language for transcription (leave blank for auto-detect)
# Options: hi (Hindi), en (English), or blank for auto
TRANSCRIPTION_LANGUAGE=

# Enable speaker diarization (requires pyannote.audio)
# Set to true only if pyannote.audio is installed
ENABLE_SPEAKER_DIARIZATION=false

# HuggingFace token (required only if ENABLE_SPEAKER_DIARIZATION=true)
HUGGINGFACE_TOKEN=
